<?xml version="1.0" encoding="utf-8"?>
<!-- Login.jsx — logo 168dp, welcome title, Google (secondary) + Guest (ghost) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingEnd="32dp"
    android:translationY="-24dp">

    <ImageView
        android:layout_width="168dp"
        android:layout_height="168dp"
        android:contentDescription="@string/app_full_name"
        android:src="@drawable/freshkeep_logo" />

    <TextView
        style="@style/Text.H2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="@string/login_welcome"
        android:textSize="19sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/btn_secondary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_google" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/baloo2_bold"
                android:text="@string/login_google"
                android:textColor="@color/color_primary_press"
                android:textSize="17sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnGuest"
            style="@style/Btn.Ghost"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:text="@string/login_guest" />
    </LinearLayout>
</LinearLayout>
