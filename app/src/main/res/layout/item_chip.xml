<?xml version="1.0" encoding="utf-8"?>
<!-- Chip.jsx — 40dp pill, optional icon, tone green -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="40dp"
    android:background="@drawable/bg_pill_primary_surface"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <com.freshkeep.app.views.IconView
        android:id="@+id/chipIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="6dp"
        android:text="eco"
        android:textColor="@color/color_primary_press"
        android:textSize="18dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/chipLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_bold"
        android:text="All"
        android:textColor="@color/color_primary_press"
        android:textSize="13sp" />
</LinearLayout>
