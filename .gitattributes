# Normalize all text files to LF in the repository.
# Working-copy endings are left to each developer's core.autocrlf setting.
* text=auto eol=lf

# Windows-only scripts must keep CRLF or cmd.exe mis-parses them.
*.bat text eol=crlf
*.cmd text eol=crlf

# Unix scripts must keep LF even when checked out on Windows.
gradlew text eol=lf
*.sh    text eol=lf

# Explicit binary declarations — prevents any eol munging or bogus diffs.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.jar   binary
*.apk   binary
*.aab   binary
*.keystore binary
*.jks   binary
*.so    binary
*.pdf   binary
