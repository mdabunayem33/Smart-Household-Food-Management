<?xml version="1.0" encoding="utf-8"?>
<!-- CategoryCard.jsx — square tone tile, illustration (48%) or icon 40, label -->
<com.freshkeep.app.views.SquareFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/catCardRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_primary_surface_lg"
        android:elevation="1dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/catIllustration"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:elevation="2dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ill_others" />

        <com.freshkeep.app.views.IconView
            android:id="@+id/catIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="category"
            android:textColor="@color/green_700"
            android:textSize="40dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/catLabel"
            style="@style/Text.H3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Vegetables"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- selection outline (AddFood custom sheets) -->
    <View
        android:id="@+id/catOutline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_category_outline"
        android:visibility="gone" />

    <!-- edit + remove badges (AddFood grids) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/catEdit"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/circle_badge"
            android:clickable="true"
            android:elevation="3dp"
            android:focusable="true"
            android:visibility="gone">

            <com.freshkeep.app.views.IconView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="edit"
                android:textColor="@color/color_text_secondary"
                android:textSize="14dp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/catRemove"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/circle_badge"
            android:clickable="true"
            android:elevation="3dp"
            android:focusable="true"
            android:visibility="gone">

            <com.freshkeep.app.views.IconView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="close"
                android:textColor="@color/color_text_secondary"
                android:textSize="14dp" />
        </FrameLayout>
    </LinearLayout>
</com.freshkeep.app.views.SquareFrameLayout>
