<?xml version="1.0" encoding="utf-8"?>
<!-- Onboarding.jsx — Skip · scene tile 240dp · title/body · dots · Next button -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/btnSkip"
            style="@style/Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:text="@string/action_skip"
            android:textColor="@color/color_text_tertiary" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <FrameLayout
            android:id="@+id/sceneTile"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_scene_tile">

            <ImageView
                android:id="@+id/sceneImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:importantForAccessibility="no"
                android:src="@drawable/scene_track" />
        </FrameLayout>

        <TextView
            android:id="@+id/obTitle"
            style="@style/Text.H1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="@string/ob_track_title" />

        <TextView
            android:id="@+id/obBody"
            style="@style/Text.BodyLg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/ob_track_body"
            android:textColor="@color/color_text_secondary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/dot0"
                android:layout_width="24dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_active" />

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_inactive" />

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/dot_inactive" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnNext"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="24dp"
        android:text="@string/action_next" />
</LinearLayout>
