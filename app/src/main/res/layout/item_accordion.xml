<?xml version="1.0" encoding="utf-8"?>
<!-- Accordion card (UserManual / legal pages) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:background="@drawable/bg_card_lg"
    android:elevation="1dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/accHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/accIconTile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/circle_primary_surface">

            <com.freshkeep.app.views.IconView
                android:id="@+id/accIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="inventory_2"
                android:textColor="@color/color_primary_press"
                android:textSize="20dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/accTitle"
            style="@style/Text.BodyLg"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/nunito_semibold"
            android:text="Add Inventory" />

        <com.freshkeep.app.views.IconView
            android:id="@+id/accChevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="expand_more"
            android:textColor="@color/color_text_tertiary"
            android:textSize="20dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/accContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:visibility="gone" />
</LinearLayout>
