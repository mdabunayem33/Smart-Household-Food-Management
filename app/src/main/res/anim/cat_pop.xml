<?xml version="1.0" encoding="utf-8"?>
<!-- @keyframes cat-pop: scale 0.7→1 + fade, 420ms ease-bounce -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="420"
    android:interpolator="@interpolator/ease_bounce">
    <scale android:fromXScale="0.7" android:toXScale="1"
        android:fromYScale="0.7" android:toYScale="1"
        android:pivotX="50%" android:pivotY="50%" />
    <alpha android:fromAlpha="0" android:toAlpha="1" />
</set>
