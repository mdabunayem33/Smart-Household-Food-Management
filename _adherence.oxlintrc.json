{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/illustrations/**",
              "components/navigation/**",
              "ui_kits/freshkeep-app/**",
              "ui_kits/freshkeep-app/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|icon|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: label, tone, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:fresh|aging|soon|expired|info)$/]",
        "message": "<Badge> tone must be one of 'fresh' | 'aging' | 'soon' | 'expired' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onChange|key|ref|className|style|children)$/]",
        "message": "<BottomNav> doesn't accept that prop. Declared props: active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomNav'] > JSXAttribute[name.name='active'] > Literal[value!=/^(?:home|inventory|shopping|analytics|profile)$/]",
        "message": "<BottomNav> active must be one of 'home' | 'inventory' | 'shopping' | 'analytics' | 'profile'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|icon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, icon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|illustration|tone|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<CategoryCard> doesn't accept that prop. Declared props: label, icon, illustration, tone, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|orange|red|blue)$/]",
        "message": "<CategoryCard> tone must be one of 'green' | 'orange' | 'red' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|selected|onClick|tone|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: label, icon, selected, onClick, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|green|orange|red|blue)$/]",
        "message": "<Chip> tone must be one of 'neutral' | 'green' | 'orange' | 'red' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FAB'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|onClick|label|key|ref|className|style|children)$/]",
        "message": "<FAB> doesn't accept that prop. Declared props: icon, onClick, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='FoodCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|quantity|icon|illustration|freshness|expiryLabel|onClick|key|ref|className|style|children)$/]",
        "message": "<FoodCard> doesn't accept that prop. Declared props: name, quantity, icon, illustration, freshness, expiryLabel, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='FoodCard'] > JSXAttribute[name.name='freshness'] > Literal[value!=/^(?:fresh|aging|soon|expired)$/]",
        "message": "<FoodCard> freshness must be one of 'fresh' | 'aging' | 'soon' | 'expired'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FoodIllustration'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|size|key|ref|className|style|children)$/]",
        "message": "<FoodIllustration> doesn't accept that prop. Declared props: type, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='FoodIllustration'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:tomato|vegetables|fruits|frozen|meat|fish|milk|snacks|drinks|rice|spices|others)$/]",
        "message": "<FoodIllustration> type must be one of 'tomato' | 'vegetables' | 'fruits' | 'frozen' | 'meat' | 'fish' | 'milk' | 'snacks' | 'drinks' | 'rice' | 'spices' | 'others'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FreshnessBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|label|expiredDays|key|ref|className|style|children)$/]",
        "message": "<FreshnessBar> doesn't accept that prop. Declared props: level, label, expiredDays."
      },
      {
        "selector": "JSXOpeningElement[name.name='FreshnessBar'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:fresh|aging|soon|expired)$/]",
        "message": "<FreshnessBar> level must be one of 'fresh' | 'aging' | 'soon' | 'expired'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|variant|onClick|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, variant, onClick, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|surface|filled)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'surface' | 'filled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OnboardingScene'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|size|key|ref|className|style|children)$/]",
        "message": "<OnboardingScene> doesn't accept that prop. Declared props: type, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='OnboardingScene'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:track|reminders|shopping)$/]",
        "message": "<OnboardingScene> type must be one of 'track' | 'reminders' | 'shopping'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|size|stroke|color|label|sublabel|key|ref|className|style|children)$/]",
        "message": "<ProgressRing> doesn't accept that prop. Declared props: value, size, stroke, color, label, sublabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReminderChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:timing|tone|onRemove|key|ref|className|style|children)$/]",
        "message": "<ReminderChip> doesn't accept that prop. Declared props: timing, tone, onRemove."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReminderChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gentle|urgent|critical)$/]",
        "message": "<ReminderChip> tone must be one of 'gentle' | 'urgent' | 'critical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|min|max|step|unit|onChange|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, defaultValue, min, max, step, unit, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|tone|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, icon, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|orange|blue|red)$/]",
        "message": "<StatCard> tone must be one of 'green' | 'orange' | 'blue' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SuccessCelebration'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|sublabel|onDone|key|ref|className|style|children)$/]",
        "message": "<SuccessCelebration> doesn't accept that prop. Declared props: message, sublabel, onDone."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|icon|type|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, placeholder, value, onChange, icon, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|onBack|action|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: title, onBack, action."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
