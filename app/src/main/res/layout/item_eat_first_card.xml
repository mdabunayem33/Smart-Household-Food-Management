<?xml version="1.0" encoding="utf-8"?>
<!-- EatFirst card — 4dp urgency stripe, 52dp tile, freshness bar, consume btn -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_lg"
    android:elevation="2dp">

    <View
        android:id="@+id/efStripe"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_stripe" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:id="@+id/efBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/efTile"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_section_md">

                <ImageView
                    android:id="@+id/efIllustration"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:importantForAccessibility="no"
                    android:padding="8dp"
                    android:src="@drawable/ill_others" />

                <com.freshkeep.app.views.IconView
                    android:id="@+id/efIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="category"
                    android:textColor="@color/color_text_primary"
                    android:textSize="24dp"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/efName"
                        style="@style/Text.H3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Tomato"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/efQty"
                        style="@style/Text.BodySm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="6 pcs"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>

                <com.freshkeep.app.views.FreshnessBarView
                    android:id="@+id/efBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/efLabel"
                    style="@style/Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Expires today"
                    android:textColor="@color/color_text_tertiary" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnConsume"
            style="@style/Btn.Secondary.Sm"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:text="Mark as Consumed" />
    </LinearLayout>
</FrameLayout>
