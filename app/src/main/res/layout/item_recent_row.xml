<?xml version="1.0" encoding="utf-8"?>
<!-- Home "Recently added" row — 56dp elevated card, 36dp tile + name -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@drawable/bg_card_lg"
    android:clickable="true"
    android:elevation="1dp"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <FrameLayout
        android:id="@+id/recentTile"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_tile_md">

        <ImageView
            android:id="@+id/recentIllustration"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:importantForAccessibility="no"
            android:padding="5dp"
            android:src="@drawable/ill_others" />

        <com.freshkeep.app.views.IconView
            android:id="@+id/recentIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="category"
            android:textColor="@color/color_primary_press"
            android:textSize="20dp"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/recentName"
        style="@style/Text.BodyLg"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Tomato" />
</LinearLayout>
