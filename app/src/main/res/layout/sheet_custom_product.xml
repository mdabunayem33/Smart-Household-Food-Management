<?xml version="1.0" encoding="utf-8"?>
<!-- Add/edit custom product sheet (AddFood.jsx) -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/dot_inactive" />

        <TextView
            android:id="@+id/cpTitle"
            style="@style/Text.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Add New Product" />

        <TextView
            android:id="@+id/cpCategory"
            style="@style/Text.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Category: Fish"
            android:textColor="@color/color_text_tertiary" />

        <TextView
            style="@style/Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Product name"
            android:textColor="@color/color_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_section_md"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <EditText
                android:id="@+id/cpName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:fontFamily="@font/nunito_semibold"
                android:hint="e.g. Hilsa"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_tertiary"
                android:textSize="17sp" />
        </LinearLayout>

        <TextView
            style="@style/Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Product image"
            android:textColor="@color/color_text_secondary" />

        <com.freshkeep.app.views.FlowLayout
            android:id="@+id/cpImageModes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <TextView
            style="@style/Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Default unit"
            android:textColor="@color/color_text_secondary" />

        <com.freshkeep.app.views.FlowLayout
            android:id="@+id/cpUnits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <TextView
            style="@style/Text.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Default expiry duration (days, optional)"
            android:textColor="@color/color_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_section_md"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <EditText
                android:id="@+id/cpExpiry"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:fontFamily="@font/nunito_semibold"
                android:hint="e.g. 14"
                android:importantForAutofill="no"
                android:inputType="number"
                android:maxLines="1"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_tertiary"
                android:textSize="17sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/cpCancel"
                style="@style/Btn.Ghost"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="Cancel" />

            <Button
                android:id="@+id/cpSave"
                style="@style/Btn.Primary"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Save" />
        </LinearLayout>

        <Button
            android:id="@+id/cpDelete"
            style="@style/Btn.Danger"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:text="Delete product"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
