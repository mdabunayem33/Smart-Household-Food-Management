<?xml version="1.0" encoding="utf-8"?>
<!-- Analytics.jsx — filter pill + waste bar chart card + dashboard pie card -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/Text.H1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/analytics_title" />

            <LinearLayout
                android:id="@+id/btnFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_section"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/filterLabel"
                    style="@style/Text.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_this_month"
                    android:textColor="@color/color_text_secondary" />

                <com.freshkeep.app.views.IconView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="expand_more"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="18dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Monthly Food Waste card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_card_lg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/Text.H2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/analytics_monthly_waste" />

            <TextView
                style="@style/Text.BodySm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="@string/analytics_waste_subtitle"
                android:textColor="@color/color_text_secondary" />

            <com.freshkeep.app.views.BarChartView
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="160dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_section_md"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/totalWaste"
                        style="@style/Text.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10.5 kg"
                        android:textColor="@color/red_700" />

                    <TextView
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/analytics_total_wasted"
                        android:textColor="@color/color_text_tertiary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_section_md"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/avgWaste"
                        style="@style/Text.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.6 kg"
                        android:textColor="@color/color_primary_press" />

                    <TextView
                        style="@style/Text.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/analytics_avg_waste"
                        android:textColor="@color/color_text_tertiary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Food Management Dashboard card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_lg"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text.H2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/analytics_dashboard" />

                <LinearLayout
                    android:id="@+id/insightBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_primary_surface"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp">

                    <com.freshkeep.app.views.IconView
                        android:id="@+id/insightBadgeIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="check_circle"
                        android:textColor="@color/green_700"
                        android:textSize="15dp" />

                    <TextView
                        android:id="@+id/insightBadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/nunito_bold"
                        android:text="-25%"
                        android:textColor="@color/green_700"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <com.freshkeep.app.views.PieChartView
                android:id="@+id/pieChart"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:id="@+id/legendContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
