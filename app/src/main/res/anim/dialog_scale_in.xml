<?xml version="1.0" encoding="utf-8"?>
<!-- @keyframes rc-dialog-in / inv-dialog-in: scale 0.92→1 + fade, 200ms ease-out-soft -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="200"
    android:interpolator="@interpolator/ease_out_soft">
    <scale android:fromXScale="0.92" android:toXScale="1"
        android:fromYScale="0.92" android:toYScale="1"
        android:pivotX="50%" android:pivotY="50%" />
    <alpha android:fromAlpha="0" android:toAlpha="1" />
</set>
