<?xml version="1.0" encoding="utf-8"?>
<!-- AdjustQuantity.jsx — item card, big value, infinite wheel, unit chips -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:orientation="vertical">

    <include
        android:id="@+id/topBar"
        layout="@layout/view_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_lg"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/aqTile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_tile_md">

                    <ImageView
                        android:id="@+id/aqIllustration"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ill_others" />

                    <com.freshkeep.app.views.IconView
                        android:id="@+id/aqIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="category"
                        android:textColor="@color/color_primary_press"
                        android:textSize="24dp"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/aqName"
                        style="@style/Text.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tomato" />

                    <TextView
                        android:id="@+id/aqCurrent"
                        style="@style/Text.BodySm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current quantity: 6 pcs"
                        android:textColor="@color/color_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/aqValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/baloo2_extrabold"
                android:gravity="center"
                android:text="1 Kg"
                android:textColor="@color/color_primary_press"
                android:textSize="40sp" />

            <com.freshkeep.app.views.QuantityWheelView
                android:id="@+id/aqWheel"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="24dp" />

            <TextView
                style="@style/Text.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Unit"
                android:textColor="@color/color_text_secondary" />

            <com.freshkeep.app.views.FlowLayout
                android:id="@+id/aqUnitChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Cancel 35% / Save 65% of the row, so both scale with the screen.
         The shared Btn style adds 32dp side padding, which left too little
         room for "Cancel" and wrapped it — overridden per button below. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:weightSum="100">

        <Button
            android:id="@+id/btnCancel"
            style="@style/Btn.Ghost"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="35"
            android:ellipsize="none"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:text="Cancel" />

        <Button
            android:id="@+id/btnSave"
            style="@style/Btn.Primary"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginStart="10dp"
            android:layout_weight="65"
            android:ellipsize="none"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:text="Save" />
    </LinearLayout>
</LinearLayout>
