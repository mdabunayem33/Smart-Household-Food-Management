<?xml version="1.0" encoding="utf-8"?>
<!-- ShoppingSetup (Shopping.jsx) — icon tile, title, subtitle, 3 options, Continue -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="48dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_icon_tile_xl">

        <com.freshkeep.app.views.IconView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="event_repeat"
            android:textColor="@color/color_primary_press"
            android:textSize="36dp" />
    </FrameLayout>

    <TextView
        style="@style/Text.H1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/setup_title" />

    <TextView
        style="@style/Text.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/setup_subtitle"
        android:textColor="@color/color_text_secondary" />

    <LinearLayout
        android:id="@+id/optionsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <Button
        android:id="@+id/btnContinue"
        style="@style/Btn.Primary"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:alpha="0.45"
        android:enabled="false"
        android:text="@string/action_continue" />
</LinearLayout>
