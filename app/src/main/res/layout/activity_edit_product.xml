<?xml version="1.0" encoding="utf-8"?>
<!-- EditProduct.jsx — name field, category chips, quantity wheel, expiry wheel -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg"
    android:orientation="vertical">

    <include
        android:id="@+id/topBar"
        layout="@layout/view_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="8dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- name card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_lg"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/epTile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_tile_md">

                    <ImageView
                        android:id="@+id/epIllustration"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:importantForAccessibility="no"
                        android:padding="8dp"
                        android:src="@drawable/ill_others" />

                    <com.freshkeep.app.views.IconView
                        android:id="@+id/epIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="category"
                        android:textColor="@color/color_primary_press"
                        android:textSize="24dp"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product name"
                        android:textColor="@color/color_text_secondary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_section_md"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <EditText
                            android:id="@+id/epName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@null"
                            android:fontFamily="@font/nunito_semibold"
                            android:importantForAutofill="no"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/color_text_primary"
                            android:textSize="17sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- category -->
            <TextView
                style="@style/Text.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Category"
                android:textColor="@color/color_text_secondary" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/epCategoryChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp" />
            </HorizontalScrollView>

            <!-- quantity -->
            <TextView
                style="@style/Text.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Quantity"
                android:textColor="@color/color_text_secondary" />

            <TextView
                android:id="@+id/epQtyValue"
                style="@style/Text.Numeral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="1 Kg"
                android:textColor="@color/color_primary_press" />

            <com.freshkeep.app.views.QuantityWheelView
                android:id="@+id/epQtyWheel"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="10dp" />

            <com.freshkeep.app.views.FlowLayout
                android:id="@+id/epUnitChips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp" />

            <!-- expiry duration -->
            <TextView
                style="@style/Text.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Expiry Duration"
                android:textColor="@color/color_text_secondary" />

            <TextView
                android:id="@+id/epDaysValue"
                style="@style/Text.Numeral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="15 Days"
                android:textColor="@color/color_primary_press" />

            <com.freshkeep.app.views.QuantityWheelView
                android:id="@+id/epDaysWheel"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_section_md"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <TextView
                    style="@style/Text.BodySm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Expiry date"
                    android:textColor="@color/color_text_secondary" />

                <TextView
                    android:id="@+id/epExpiryDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="4 August 2026"
                    android:textColor="@color/color_primary_press"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp">

        <Button
            android:id="@+id/btnCancel"
            style="@style/Btn.Ghost"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="Cancel" />

        <Button
            android:id="@+id/btnSave"
            style="@style/Btn.Primary"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginStart="10dp"
            android:layout_weight="2"
            android:text="Save Changes" />
    </LinearLayout>
</LinearLayout>
