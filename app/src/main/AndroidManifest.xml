<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- allowBackup must stay false: Android's auto-backup would restore the
         SQLite session/onboarding flags after a reinstall, silently skipping
         onboarding on what should be a first launch -->
    <application
        android:name=".FreshKeepApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.FreshKeep"
        tools:targetApi="31">

        <!-- singleTask + the isTaskRoot guard in the activity keep exactly one
             Splash instance, so the splash can never be shown twice -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.FreshKeep.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.OnboardingActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".activities.ShoppingSetupActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />
        <activity
            android:name=".activities.AddFoodActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".activities.EatFirstActivity" android:exported="false" />
        <activity android:name=".activities.AdjustQuantityActivity" android:exported="false" />
        <activity android:name=".activities.EditProductActivity" android:exported="false" />
        <activity android:name=".activities.ManualAddShoppingActivity" android:exported="false" />
        <activity android:name=".activities.ReminderPrefsActivity" android:exported="false" />
        <activity android:name=".activities.LanguageActivity" android:exported="false" />
        <activity android:name=".activities.UserManualActivity" android:exported="false" />
        <activity android:name=".activities.AboutActivity" android:exported="false" />
        <activity android:name=".activities.PrivacyPolicyActivity" android:exported="false" />
        <activity android:name=".activities.TermsActivity" android:exported="false" />

        <!-- Re-arms expiry reminders after reboot / app update -->
        <receiver
            android:name=".notifications.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
