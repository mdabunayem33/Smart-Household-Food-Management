<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     TYPE STYLES — transcribed 1:1 from tokens/typography.css
       display  = Baloo 2 (headings, greetings, numerals)
       body     = Nunito  (body copy, labels, captions)
     Sizes are sp; line heights via lineSpacingMultiplier.
     ============================================================ -->
<resources>
    <!-- Display / Headings — Baloo 2 700 -->
    <style name="Text.DisplayLg" parent="">
        <item name="android:fontFamily">@font/baloo2_bold</item>
        <item name="android:textSize">40sp</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.Display" parent="">
        <item name="android:fontFamily">@font/baloo2_bold</item>
        <item name="android:textSize">32sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.H1" parent="">
        <item name="android:fontFamily">@font/baloo2_bold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.H2" parent="">
        <item name="android:fontFamily">@font/baloo2_bold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.H3" parent="">
        <item name="android:fontFamily">@font/baloo2_bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingMultiplier">1.35</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <!-- Body / UI — Nunito -->
    <style name="Text.BodyLg" parent="">
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textSize">17sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.Body" parent="">
        <item name="android:fontFamily">@font/nunito_medium</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.BodySm" parent="">
        <item name="android:fontFamily">@font/nunito_medium</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.45</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.Caption" parent="">
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.Label" parent="">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.Overline" parent="">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <!-- Numerals — Baloo 2 800 -->
    <style name="Text.NumeralLg" parent="">
        <item name="android:fontFamily">@font/baloo2_extrabold</item>
        <item name="android:textSize">36sp</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Text.Numeral" parent="">
        <item name="android:fontFamily">@font/baloo2_extrabold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>

    <!-- ============================================================
         BUTTONS — Button.jsx: pill, Baloo 2 bold, sizes lg 64 / md 56 / sm 48
         ============================================================ -->
    <style name="Btn" parent="">
        <item name="android:minHeight">64dp</item>
        <item name="android:height">64dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/baloo2_bold</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="Btn.Primary">
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">@color/color_text_inverse</item>
        <item name="android:elevation">6dp</item>
    </style>
    <style name="Btn.Secondary">
        <item name="android:background">@drawable/btn_secondary</item>
        <item name="android:textColor">@color/color_primary_press</item>
    </style>
    <style name="Btn.Ghost">
        <item name="android:background">@drawable/btn_ghost</item>
        <item name="android:textColor">@color/color_text_primary</item>
    </style>
    <style name="Btn.Danger">
        <item name="android:background">@drawable/btn_danger</item>
        <item name="android:textColor">@color/color_text_inverse</item>
    </style>

    <!-- md size = height 56, padding 28, 15sp -->
    <style name="Btn.Primary.Md">
        <item name="android:minHeight">56dp</item>
        <item name="android:height">56dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="Btn.Secondary.Md">
        <item name="android:minHeight">56dp</item>
        <item name="android:height">56dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="Btn.Ghost.Md">
        <item name="android:minHeight">56dp</item>
        <item name="android:height">56dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="Btn.Danger.Md">
        <item name="android:minHeight">56dp</item>
        <item name="android:height">56dp</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- sm size = height 48, padding 20, 14sp -->
    <style name="Btn.Secondary.Sm">
        <item name="android:minHeight">48dp</item>
        <item name="android:height">48dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
